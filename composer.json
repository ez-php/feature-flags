{
    "name": "ez-php/feature-flags",
    "version": "1.5.1",
    "description": "Simple feature flag evaluation for the ez-php framework — File, Database, and Array drivers with a static Flag facade",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Andreas Uretschnig",
            "email": "andreas.uretschnig@gmail.com"
        }
    ],
    "keywords": [
        "feature-flags",
        "feature-toggles",
        "flags",
        "rollout",
        "php",
        "framework",
        "ez-php"
    ],
    "homepage": "https://github.com/ez-php/feature-flags",
    "support": {
        "issues": "https://github.com/ez-php/feature-flags/issues",
        "source": "https://github.com/ez-php/feature-flags"
    },
    "require": {
        "php": "^8.5",
        "ez-php/contracts": "^1.0"
    },
    "require-dev": {
        "ez-php/docker": "^1.0",
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "EzPhp\\FeatureFlags\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "cs": "php-cs-fixer fix",
        "analyse": "phpstan analyse",
        "test": "phpunit",
        "full": "composer analyse && composer cs && composer test"
    }
}
